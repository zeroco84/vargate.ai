{
  "uid": "vargate-usage",
  "title": "Vargate Product Usage",
  "timezone": "utc",
  "refresh": "30s",
  "schemaVersion": 39,
  "time": {
    "from": "now-30d",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Total Signups",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "gateway_funnel_total_signups",
          "legendFormat": "signups",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Activated",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "gateway_funnel_total_activated",
          "legendFormat": "activated",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Repeat Users",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "gateway_funnel_repeat_tenants",
          "legendFormat": "repeat",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "purple", "value": null }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Daily Active Tenants",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "gateway_daily_active_tenants",
          "legendFormat": "DAT",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "orange", "value": null }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Signup → Activation %",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "gateway_funnel_total_activated / gateway_funnel_total_signups * 100",
          "legendFormat": "activation rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "green", "value": 50 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Activation → Repeat %",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "expr": "gateway_funnel_repeat_tenants / gateway_funnel_total_activated * 100",
          "legendFormat": "repeat rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "green", "value": 50 }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "title": "Signups per Day",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "increase(gateway_signups_total[1d])",
          "legendFormat": "{{method}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "fillOpacity": 50 }
        }
      }
    },
    {
      "id": 8,
      "title": "Governed Actions per Day",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 14 },
      "targets": [
        {
          "expr": "sum(increase(gateway_governed_actions_total{tenant_id!~\"vargate-internal|vargate-gtm-agent\"}[1d]))",
          "legendFormat": "actions",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "fillOpacity": 50 }
        }
      }
    },
    {
      "id": 9,
      "title": "Actions by Tenant",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "sum by (tenant_id)(increase(gateway_governed_actions_total{tenant_id!~\"vargate-internal|vargate-gtm-agent\"}[1d]))",
          "legendFormat": "{{tenant_id}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 10,
      "title": "Decision Breakdown",
      "type": "piechart",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "sum by (decision)(gateway_governed_actions_total{tenant_id!~\"vargate-internal|vargate-gtm-agent\"})",
          "legendFormat": "{{decision}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {}
      }
    }
  ]
}
