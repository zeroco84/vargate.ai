# .env.production
# Copy this to .env and fill in real values before deploying.
# NEVER commit the filled-in .env to git.

# ── Domain ────────────────────────────────────────────────────────────────────
DOMAIN=vargate.ai

# ── Redis ────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
REDIS_PASSWORD=CHANGE_ME

# ── Blockchain (Legacy Hardhat) ──────────────────────────────────────────────
ANCHOR_INTERVAL_SECONDS=3600    # How often to anchor to chain (seconds)
                                 # 300 = every 5 min (sensible for demo)
                                 # In production on a real chain, 3600 (1hr) is fine

# ── Sepolia Merkle Anchoring (Stage 7B) ──────────────────────────────────────
# Get a free RPC endpoint from Alchemy or Infura.
# See DEPLOY.md for full setup instructions.
SEPOLIA_RPC_URL=               # e.g. https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
DEPLOYER_PRIVATE_KEY=          # 64-char hex private key (no 0x prefix)
ETHERSCAN_API_KEY=             # Optional, for contract verification

# ── Gateway ──────────────────────────────────────────────────────────────────
# These should match what your base docker-compose.yml expects.
# REDIS_URL is constructed in docker-compose.prod.yml using REDIS_PASSWORD above.
OPA_URL=http://opa:8181
BUNDLE_SERVER_URL=http://bundle-server:8080
HSM_URL=http://hsm:8300

# ── Auth & Signup (Sprint 3) ────────────────────────────────────────────────
# GitHub OAuth — create at https://github.com/settings/applications/new
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=https://vargate.ai/api/auth/github/callback

# Resend — for email verification. Get key at https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=Vargate <no-reply@vargate.ai>

# JWT secret for dashboard sessions. Generate with: openssl rand -hex 32
JWT_SECRET=

# Base URL for links in emails
VARGATE_BASE_URL=https://vargate.ai

# ── Stage 7C: AGCS compliance ───────────────────────────────────────────────
ANCHOR_MODE=full                    # 'full' (all records) or 'incremental' (new records only)
MERKLE_ROOT_INTERVAL_SECONDS=3600   # How often to locally record Merkle root (max 3600 for AG-2.2)

