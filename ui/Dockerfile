FROM node:20-alpine AS build
WORKDIR /app
COPY package.json package-lock.json* ./
RUN npm install
COPY . .
RUN npm run build

FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
# NOTE: nginx master process needs root to bind port 80. nginx worker
# processes already run as unprivileged nginx user by default.
EXPOSE 80
